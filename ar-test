<!DOCTYPE html>
<html lang="ja">
<head>
  <meta charset="UTF-8">
  <title>ARテスト</title>
  <script type="module" src="https://ajax.googleapis.com/ajax/libs/model-viewer/3.4.0/model-viewer.min.js"></script>
  <style>
    body { margin: 0; display: flex; justify-content: center; align-items: center; height: 100vh; background-color: #f0f0f0; }
    model-viewer { width: 100%; height: 100%; }
    .ar-button { position: absolute; bottom: 20px; left: 50%; transform: translateX(-50%); padding: 15px 20px; font-size: 16px; background-color: #007BFF; color: white; border: none; border-radius: 8px; }
  </style>
</head>
<body>
  <model-viewer 
    src="https://modelviewer.dev/shared-assets/models/Astronaut.glb" 
    ar 
    camera-controls 
    auto-rotate 
    shadow-intensity="1">
    <button slot="ar-button" class="ar-button">📸 部屋に置く</button>
  </model-viewer>
</body>
</html>
